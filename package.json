{
  "name": "raven",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "commit": "bash -c 'issue=$1; msg=$2; git add . && git commit -m \"#$issue: $msg\" && git push' --",
    "test:e2e": "playwright test",
    "test:e2e:update-snapshots": "playwright test --update-snapshots"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "typescript": "^6.0.3",
    "vite": "^7.0.0",
    "vite-plugin-pwa": "^1.2.0"
  }
}
